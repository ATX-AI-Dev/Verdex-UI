{
  "name": "@verdex/vue",
  "version": "0.1.0",
  "description": "Composants Vue 3 du design system Verdex.",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "main": "./dist/verdex-vue.umd.cjs",
  "module": "./dist/verdex-vue.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/verdex-vue.js",
      "require": "./dist/verdex-vue.umd.cjs"
    },
    "./style.css": "./dist/verdex-vue.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json --emitDeclarationOnly",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@verdex/tokens": "workspace:^",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vitest": "^2.0.0",
    "vue": "^3.5.35",
    "vue-tsc": "^2.2.0"
  }
}
